NODE_ENV=production
HOSTNAME=127.0.0.1
PORT=3000
DATABASE_URL=file:/var/lib/swarm56/web/site.db

# --- v5 백오피스(인증·삭제·복원·트리거) ---
# 비번 bcrypt 해시: node -e "console.log(require('bcryptjs').hashSync('실제비번',10))"
ADMIN_PASSWORD_HASH=
# 세션 서명키(필수 — 미설정 시 프로덕션 fail-closed): openssl rand -hex 32
SESSION_SECRET=
# 옵시디언 볼트 경로(복원 시 md 읽기 전용). Nginx /vault alias와 동일 루트의 raw/ 상위
SWARM56_VAULT_DIR=/var/lib/swarm56/vault
# 백오피스 트리거 파일(systemd path-unit이 감시) — clip/force
SWARM56_CLIP_TRIGGER=/var/lib/swarm56/triggers/clip.now
SWARM56_FORCE_TRIGGER=/var/lib/swarm56/triggers/force.now
