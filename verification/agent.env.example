# verification/agent.env.example
# Codex 검증 중 "토큰 필요 채널"과 "실제 LLM 발췌"를 확인하려면:
#   1) 이 파일을 verification/agent.env 로 복사
#   2) 아래 placeholder를 실제 토큰/키로 교체 (Peter가 제공)
#   3) setup_verify.ps1 이 자동으로 로드함
# 주의: verification/agent.env 에는 실제 비밀이 들어가므로 절대 커밋하지 말 것(.gitignore 권장).

# --- 토큰 필요 채널 ---
SWARM56_NOTION_TOKEN=
SWARM56_FOURSQUARE_TOKEN=
SWARM56_INSTAGRAM_TOKEN=
# (Facebook은 v5 빈 채널 — 자동 수집 안 함)

# --- 발췌 LLM (하나만 넣어도 됨; 순차 시도 openai→gemini→anthropic) ---
SWARM56_OPENAI_API_KEY=
SWARM56_GEMINI_API_KEY=
SWARM56_ANTHROPIC_API_KEY=
